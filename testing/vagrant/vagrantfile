# ============================================================
# Vagrantfile - Máquina virtual de pruebas NyxOS
# ============================================================
Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  
  config.vm.provider "virtualbox" do |vb|
    vb.memory = "4096"
    vb.cpus = 4
    vb.name = "nyx-os-dev"
  end
  
  config.vm.provision "shell", inline: <<-SHELL
    apt-get update
    apt-get install -y build-essential nasm gcc-multilib \
      grub-pc-bin grub-common xorriso mtools cpio gzip \
      qemu-system-x86 qemu-kvm git wget python3 python3-pip
    
    cd /vagrant
    chmod +x tools/build.sh
    echo "NyxOS development environment ready"
    echo "Run: ./tools/build.sh all"
  SHELL
end